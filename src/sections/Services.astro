---
import ServiceCard from "../components/services/ServiceCard.astro";
import AIImage from "../assets/cards/ai.jpg";
import WebPagesImage from "../assets/cards/web-pages.jpg";
import AuditoriesImage from "../assets/cards/auditories.jpg";
import MobileAppsImage from "../assets/cards/mobile-apps.jpg";
---

<section>
  <h2 class="underline gothic">
    <span>Servicios</span>
  </h2>

  <main>
    <ServiceCard
      title="Agentes de IA"
      description="El poder de la IA al servicio de tu negocio. Automatiza tareas y mejora la eficiencia."
      img={AIImage}
      icon="ai"
    />
    <ServiceCard
      title="Desarrollo Web"
      description="Creamos sitios web modernos y responsivos para tu negocio."
      img={WebPagesImage}
      icon="desktop"
    />
    <ServiceCard
      title="Desarrollo de Aplicaciones"
      description="Creamos aplicaciones móviles y de escritorio a medida para tu negocio."
      img={MobileAppsImage}
      icon="mobile"
    />
    <ServiceCard
      title="Análisis de Datos"
      description="Transformamos tus datos en información valiosa para la toma de decisiones."
      img={AuditoriesImage}
      icon="data"
    />
  </main>
</section>


<style>
  section {
    padding-block: var(--space-10);
    padding-inline: var(--space-10);
  }

  h2 {
    color: var(--color-primary);
    font-size: clamp(var(--font-size-2xl), 4vw + 1rem, var(--font-size-5xl));
    margin-bottom: 1rem;
    text-align: center;
  }

  main {
      
    display: grid;
    height: fit-content;
    width: 100%;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    grid-auto-rows: 150px;
    gap: var(--space-10);
    padding-block: var(--space-8);
 
    box-sizing: border-box;
    max-width: var(--breakpoint-3xl);
    margin-inline: auto; */
  
  }

  main::-webkit-scrollbar {
    display: none; /* Chrome, Safari y Opera */
  }

  @media screen and (width < 640px) {
    main{
      grid-template-columns: 1fr;
    }
  }
</style>
